# Secrets : NE JAMAIS commit le fichier .env (contient la cle API).
.env

# Donnees personnelles : profil utilisateur local.
user_profile.json
# Memoire persistante de l'agent (faits retenus entre sessions).
memoire.json
# Sauvegardes locales des ecritures de fichiers (/undo).
.baziz_backups/

# Conversations sauvegardees (multi-sessions, /continue, /sessions, /new).
sessions/
# Ancien fichier unique (avant le multi-session) + sa sauvegarde de migration.
session_history.json*

# Marqueur local : le tutoriel /tuto a deja ete montre une fois.
tuto_complete.json

# Historique de saisie (fleche haut, persistant entre lancements).
input_history.txt

# Images generees par /create-image (sorties locales).
generated_images/

# Tout ce que BAZIZ.IA CREE pour l'utilisateur (projets, jeux, sites...) vit
# ici et ne part JAMAIS sur GitHub : c'est le bac a sable, pas le logiciel.
# (Le prompt systeme dit a l'agent de creer ses projets dans ce dossier.)
outputs/

# Plugins : espace PERSO local. Seuls les 2 exemples livres + le guide sont
# versionnes ; vos plugins (et ceux que l'agent se cree) restent PRIVES.
# Pour PARTAGER un plugin : pull request dans marketplace/ (voir son README).
plugins/*
!plugins/README.md
!plugins/meteo.py
!plugins/calculatrice.py

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/

# Outils / IDE
.vscode/
.idea/
*.swp

# Journal local (optionnel : retirez cette ligne pour le versionner)
# JOURNAL.txt

# Config locale d'outillage (previews...)
.claude/
