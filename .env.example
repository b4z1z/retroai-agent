# ============================================================
#  RetroAI Agent - Exemple de configuration
#  Copiez ce fichier en ".env" puis remplissez vos valeurs :
#      cp .env.example .env
#  Le fichier .env NE DOIT JAMAIS etre commit dans git.
# ============================================================

# [OBLIGATOIRE] Votre cle API NVIDIA NIM (commence par "nvapi-").
# A recuperer sur https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [OPTIONNEL] URL de l'endpoint chat completions.
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1/chat/completions

# [OPTIONNEL] Modele utilise.
NVIDIA_MODEL=moonshotai/kimi-k2.6

# [OPTIONNEL] Mode "thinking" (raisonnement) : true / false.
ENABLE_THINKING=true

# [OPTIONNEL] Delai max (secondes) avant de tuer une commande shell bloquee.
SHELL_TIMEOUT=30

# [OPTIONNEL] Auto-executer les commandes shell LECTURE SEULE sures (ls, cat,
# echo, find, grep...) SANS confirmation. Defaut: false (tout est confirme).
# Securise : bloque toute commande contenant > | ; & $ (...) ou find -exec/-delete.
AUTO_SAFE_COMMANDS=false
