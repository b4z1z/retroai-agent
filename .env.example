# ============================================================
#  RetroAI Agent - Exemple de configuration
#  Copiez ce fichier en ".env" puis remplissez vos valeurs :
#      cp .env.example .env
#  Le fichier .env NE DOIT JAMAIS etre commit dans git.
# ============================================================

# [OBLIGATOIRE] Votre cle API NVIDIA NIM (commence par "nvapi-").
# A recuperer sur https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [OPTIONNEL] URL de l'endpoint chat completions.
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1/chat/completions

# [OPTIONNEL] Modele utilise. LIBRE : n'importe quel modele du catalogue NVIDIA
# NIM, pas seulement NVIDIA. Exemples : deepseek-ai/deepseek-v4-flash,
# meta/llama-3.3-70b-instruct, qwen/..., mistralai/...  Seule contrainte : le
# modele doit supporter le tool-calling (l'agent en a besoin pour agir).
# Catalogue complet : https://build.nvidia.com/models
NVIDIA_MODEL=nvidia/nemotron-3-ultra-550b-a55b

# [OPTIONNEL] Mode "thinking" (raisonnement) : true / false. (compat ; voir
# THINKING_LEVEL ci-dessous qui le pilote desormais plus finement.)
ENABLE_THINKING=true

# [OPTIONNEL] Niveau d'effort de reflexion (reglable a chaud via /think) :
# low / medium / high / highx / ultra. Plus haut = plus pousse (et plus lent).
THINKING_LEVEL=medium

# [OPTIONNEL] Longueur max de la reponse (tokens). 0 = AUCUNE limite (defaut) :
# le modele genere jusqu'a son maximum (ideal pour du long code). Mets une
# valeur > 0 seulement si tu veux plafonner volontairement.
MAX_TOKENS=0

# [OPTIONNEL] Delai max (secondes) avant de tuer une commande shell bloquee.
SHELL_TIMEOUT=30

# [OPTIONNEL] Delai max (secondes) d'UNE requete API. Augmente-le pour de
# grosses generations (/think ultra sur un gros fichier). Defaut: 300.
REQUEST_TIMEOUT=300

# [OPTIONNEL] Streaming : reponse affichee morceau par morceau (comme Claude),
# evite les timeouts sur les longues generations. true / false. Defaut: true.
# (false = ancien mode : reponse complete d'un coup, rendu Markdown.)
STREAM=true

# [OPTIONNEL] Auto-executer les commandes shell LECTURE SEULE sures (ls, cat,
# echo, find, grep...) SANS confirmation. Defaut: false (tout est confirme).
# Securise : bloque toute commande contenant > | ; & $ (...) ou find -exec/-delete.
AUTO_SAFE_COMMANDS=false

# [OPTIONNEL] Generation d'images (/create-image). Modele SEPARE du chat
# (les modeles de chat ne creent pas d'images), appele avec la MEME cle NVIDIA.
# FLUX par defaut ; pour du plus rapide : stabilityai/sdxl-turbo
IMAGE_MODEL=black-forest-labs/flux.1-dev
IMAGE_BASE_URL=https://ai.api.nvidia.com/v1/genai

# [OPTIONNEL] Fournisseur d'images : "nvidia" (FLUX, defaut) ou "gemini"
# (Nano Banana, meilleure qualite). Tu peux aussi changer ca via /image
# dans l'app (la cle Gemini est alors demandee et enregistree ici tout seul).
IMAGE_PROVIDER=nvidia
# Cle Google AI Studio (https://aistudio.google.com) - requise pour Gemini.
# GEMINI_API_KEY=AIza...
# Modele Gemini : gemini-3-pro-image (Pro) ou gemini-2.5-flash-image (Flash).
GEMINI_MODEL=gemini-3-pro-image
